PORT=5000
MONGO_URI=mongodb://localhost:27017/tweet_subscription_app
JWT_SECRET=changeThisSecretKey123

# set to true to skip Razorpay entirely and simulate successful payments
DEMO_MODE=true

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# gmail or any smtp provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=youremail@gmail.com

# payment window restriction (IST)
PAYMENT_WINDOW_START_HOUR=10
PAYMENT_WINDOW_END_HOUR=11
